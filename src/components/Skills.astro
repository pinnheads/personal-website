---
import { Icon } from 'astro-icon/components';
import data from '../assets/architect-data.json';

const { skills } = data;
---

<section>
    <div class="flex items-end justify-between mb-8">
        <div class="flex items-center gap-2">
            <div class="h-px w-8 bg-orange-600 dark:bg-orange-500"></div>
            <span class="font-mono text-xs text-orange-600 dark:text-orange-500 tracking-widest">SKILLS & TOOLS</span>
        </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6 p-6 border bg-white border-black/10 dark:bg-white/5 dark:border-white/10">
        {skills.map((group) => (
            <div class="space-y-4">
                <div class="flex items-center gap-2 pb-2 border-b border-black/10 dark:border-white/10">
                    <Icon name="lucide:terminal" size={16} class="text-orange-600 dark:text-orange-500" />
                    <h3 class="font-mono text-xs font-bold tracking-wider text-black dark:text-white">
                        {group.category}
                    </h3>
                </div>
                <ul class="space-y-2">
                    {group.items.map((item) => (
                        <li class="flex items-center gap-2 text-sm font-mono text-black/60 dark:text-white/60">
                            <span class="w-1 h-1 bg-black/40 dark:bg-white/40"></span>
                            {item}
                        </li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</section>
