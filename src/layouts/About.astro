---
import { Icon } from 'astro-icon/components';
import data from '../assets/architect-data.json';

const { profile, specs } = data;
---

<div>
    <div class="inline-block px-2 py-1 border font-mono text-xs mb-4 bg-orange-100 border-orange-200 text-orange-700 dark:bg-orange-500/10 dark:border-orange-500/20 dark:text-orange-500">
        SYSTEM_ID: {profile.id}
    </div>
    
    <h1 class="text-5xl md:text-6xl font-black tracking-tighter mb-4 leading-none uppercase text-black dark:text-white">
        {profile.name.split(' ').map((n) => (
            <span class="block">{n}</span>
        ))}
    </h1>
    
    <p class="text-lg leading-relaxed max-w-xs text-black/60 dark:text-white/50 mb-12">
        {profile.bio}
    </p>

    <div class="space-y-6">
        <div class="flex items-center gap-2 mb-6">
            <div class="h-px w-8 bg-orange-600 dark:bg-orange-500"></div>
            <span class="font-mono text-xs text-orange-600 dark:text-orange-500 tracking-widest">SPECIFICATIONS</span>
        </div>

        <div class="grid gap-4">
            {specs.map((spec) => (
                <div class="flex justify-between items-end border-b border-dashed pb-2 border-black/10 dark:border-white/10">
                    <span class="text-sm font-bold text-black/40 dark:text-white/40">{spec.label}</span>
                    <span class="font-mono text-sm text-orange-700 dark:text-orange-400">{spec.value}</span>
                </div>
            ))}
        </div>
    </div>

    <div class="space-y-4 mt-12">
        <div class="flex items-center gap-2 mb-6">
            <div class="h-px w-8 bg-orange-600 dark:bg-orange-500"></div>
            <span class="font-mono text-xs text-orange-600 dark:text-orange-500 tracking-widest">CONNECT_LINKS</span>
        </div>
        
        <div class="flex gap-4">
            {profile.social.github && (
                <a href={profile.social.github} class="p-3 border border-black/10 text-black hover:bg-black hover:text-white dark:border-white/10 dark:text-white dark:hover:bg-white dark:hover:text-black transition-colors">
                    <Icon name="lucide:github" size={20} />
                </a>
            )}
            {profile.social.linkedin && (
                <a href={profile.social.linkedin} class="p-3 border border-black/10 text-black hover:bg-[#0077b5] hover:border-[#0077b5] hover:text-white dark:border-white/10 dark:text-white dark:hover:bg-[#0077b5] dark:hover:border-[#0077b5] dark:hover:text-white transition-colors">
                    <Icon name="lucide:linkedin" size={20} />
                </a>
            )}
            <a href={`mailto:${profile.email}`} class="p-3 border border-black/10 text-black hover:bg-orange-600 hover:border-orange-600 hover:text-white dark:border-white/10 dark:text-white dark:hover:bg-orange-500 dark:hover:border-orange-500 dark:hover:text-black transition-colors">
                <Icon name="lucide:mail" size={20} />
            </a>
            
            <button 
                id="theme-toggle"
                class="p-3 border ml-auto border-black/10 text-black hover:bg-black hover:text-white dark:border-white/10 dark:text-white dark:hover:bg-white dark:hover:text-black transition-colors"
            >
                <Icon name="lucide:sun" size={20} class="hidden dark:block" />
                <Icon name="lucide:moon" size={20} class="block dark:hidden" />
            </button>
        </div>
    </div>
</div>

<script lang="ts">
    const btn = document.getElementById('theme-toggle');
    if (btn) {
        btn.addEventListener('click', () => {
            // Check if window.toggleTheme is available (it should be from BaseLayout)
            if (window.toggleTheme) {
                window.toggleTheme();
            }
        });
    }
</script>