---
import data from '../assets/architect-data.json';

const { experience } = data;
---

<section>
    <div class="flex items-center gap-2 mb-6">
        <div class="h-px w-8 bg-orange-600 dark:bg-orange-500"></div>
        <span class="font-mono text-xs text-orange-600 dark:text-orange-500 tracking-widest">EXPERIENCE</span>
    </div>

    <div class="relative pl-8 border-l space-y-12 border-black/10 dark:border-white/10">
        {experience.map((job) => (
            <div class="relative group">
                <div class="absolute -left-[37px] top-1.5 w-4 h-4 border flex items-center justify-center bg-[#F0F0F0] border-orange-600 dark:bg-[#0A0A0A] dark:border-orange-500">
                    <div class="w-1.5 h-1.5 bg-orange-600 dark:bg-orange-500"></div>
                </div>
                
                <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
                    <h3 class="text-xl font-bold text-black dark:text-white">{job.company}</h3>
                    <span class="font-mono text-xs px-2 py-1 text-orange-700 bg-orange-100 dark:text-orange-500 dark:bg-orange-500/10">
                        {job.period}
                    </span>
                </div>
                <div class="font-mono text-sm mb-4 text-black/60 dark:text-white/60">{job.role}</div>
                <p class="leading-relaxed mb-4 text-black/50 dark:text-white/50">
                    {job.description}
                </p>
                <div class="flex flex-wrap gap-2">
                    {job.tech && job.tech.map((t) => (
                        <span class="text-[10px] font-mono border-b pb-0.5 text-black/20 border-black/10 dark:text-white/80 dark:border-white/10">
                            {t}
                        </span>
                    ))}
                </div>
            </div>
        ))}
    </div>
</section>
